---
import Layout from '../layouts/Layout.astro';
import LineButton from '../components/LineButton.astro';
import { getCourses } from '../lib/notion';

const base = import.meta.env.BASE_URL;
const joinUrl = `${base.replace(/\/$/, '')}/join`;

const allCourses = await getCourses();

// 養成講座（種別で判定）
const certCourses = allCourses
  .filter((c) => c.type === '養成講座')
  .map((c) => ({
    name: c.name,
    course: c.courseName,
    period: c.period,
    instructor: c.instructor,
    target: c.desc,
    afterCare: c.afterCare,
    online: c.method,
    note: c.note,
    curriculum: c.curriculum,
    extra: c.extra,
  }));

// カテゴリ別メタ（アイコン・リード文はコード側で保持）
const CATEGORY_META: Record<string, { icon: string; lead: string }> = {
  'キャリア・デビュー支援': {
    icon: '🧭',
    lead: '方向性を定め、実力を判定し、占い師としてデビューする',
  },
  '体験講座（はじめての方へ）': {
    icon: '🌱',
    lead: 'まずは気軽に。占いの世界にふれる入門講座',
  },
  '練習会・ロールプレイ': { icon: '🃏', lead: '実践を重ね、読みと伝え方を磨く' },
  '集客・収益化・ビジネス': {
    icon: '💰',
    lead: '占いを「稼げる仕事」にするための実務とノウハウ',
  },
  'メンタル・セルフケア': {
    icon: '🌿',
    lead: '占い師として長く活動するための心の整え方',
  },
};

// セッションをカテゴリ順（初出順＝表示順）にグルーピング
const sessionCourses = allCourses.filter((c) => c.type !== '養成講座');
const categories: {
  icon: string;
  name: string;
  lead: string;
  items: {
    title: string;
    desc: string;
    instructor: string;
    method: string;
    time: string;
    note: string;
  }[];
}[] = [];
for (const c of sessionCourses) {
  let cat = categories.find((x) => x.name === c.category);
  if (!cat) {
    const meta = CATEGORY_META[c.category] ?? { icon: '✦', lead: '' };
    cat = { icon: meta.icon, name: c.category, lead: meta.lead, items: [] };
    categories.push(cat);
  }
  cat.items.push({
    title: c.name,
    desc: c.desc,
    instructor: c.instructor,
    method: c.method,
    time: c.period,
    note: c.note,
  });
}

---

<Layout
  title="講座紹介｜Branch"
  description="Branchの養成講座とセッション・講座の一覧。プロデビューを目指す本格コースから、体験講座・練習会・収益化・メンタルケアまで幅広く用意しています。"
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">講座紹介</h1>
      <p class="section-lead">
        学ぶ・練習する・稼ぐ・整える。<br />
        あなたのステージに合わせた講座とセッションを用意しています。
      </p>

      <!-- 養成講座 -->
      <div class="cat">
        <div class="cat-head">
          <span class="cat-icon">🎓</span>
          <div>
            <h2 class="cat-name">養成講座（プロデビューを目指す本格コース）</h2>
            <p class="cat-lead">占術を体系的に習得し、占い師・鑑定士としてデビューする</p>
          </div>
        </div>
        <div class="cert-grid">
          {
            certCourses.map((c) => (
              <article class="cert-card">
                <div class="cert-head">
                  <h3 class="cert-name">{c.name}</h3>
                  {c.note && <span class="badge badge-note">※ {c.note}</span>}
                </div>
                <p class="cert-course">{c.course}</p>
                <p class="cert-target">{c.target}</p>
                <div class="meta">
                  <span class="badge">👤 {c.instructor}</span>
                  <span class="badge">⏱ {c.period}</span>
                  <span class="badge">💻 {c.online}</span>
                  {c.afterCare && <span class="badge">2か月間 無料アフターフォロー付</span>}
                </div>
                <details class="curriculum">
                  <summary>カリキュラムを見る</summary>
                  <ul>
                    {c.curriculum.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                  {c.extra && <p class="cert-extra">{c.extra}</p>}
                </details>
              </article>
            ))
          }
        </div>
      </div>

      <!-- セッション・講座（テーマ別） -->
      {
        categories.map((cat) => (
          <div class="cat">
            <div class="cat-head">
              <span class="cat-icon">{cat.icon}</span>
              <div>
                <h2 class="cat-name">{cat.name}</h2>
                <p class="cat-lead">{cat.lead}</p>
              </div>
            </div>
            <ul class="course-grid">
              {cat.items.map((item) => (
                <li class="course-card">
                  <p class="course-title">{item.title}</p>
                  <p class="course-desc">{item.desc}</p>
                  <div class="meta">
                    <span class="badge">👤 {item.instructor}</span>
                    <span class="badge">⏱ {item.time}</span>
                    <span class="badge badge-method">{item.method}</span>
                  </div>
                  {item.note && <p class="course-note">※ {item.note}</p>}
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="courses-cta">
        <p>気になる講座はありましたか？ご予約・ご相談は公式LINEから。</p>
        <div class="courses-cta-actions">
          <LineButton label="LINEで予約・相談する" />
          <a class="btn btn-ghost" href={joinUrl}>参加方法を見る</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cat {
    margin-bottom: 3.5rem;
  }
  .cat-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-border);
  }
  .cat-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .cat-name {
    font-size: 1.3rem;
    color: var(--color-primary-soft);
  }
  .cat-lead {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin-top: 0.2rem;
  }

  /* 共通メタ（担当・時間・提供方法） */
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.9rem;
  }
  .badge {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .badge-method {
    background: transparent;
  }
  .badge-note {
    background: transparent;
    border-color: var(--color-accent);
    color: var(--color-accent-soft);
  }

  /* 養成講座カード */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  .cert-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .cert-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .cert-name {
    font-size: 1.25rem;
  }
  .cert-course {
    color: var(--color-primary-soft);
    font-size: 0.9rem;
    margin-top: 0.3rem;
  }
  .cert-target {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin-top: 0.8rem;
  }
  .curriculum {
    margin-top: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.8rem;
  }
  .curriculum summary {
    cursor: pointer;
    color: var(--color-primary-soft);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .curriculum ul {
    margin: 0.8rem 0 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .cert-extra {
    margin-top: 0.8rem;
    color: var(--color-accent-soft);
    font-size: 0.85rem;
  }

  /* セッション・講座カード */
  .course-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .course-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-primary);
    border-radius: 10px;
    padding: 1.2rem 1.3rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }
  .course-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  .course-title {
    font-weight: 700;
    line-height: 1.5;
    font-size: 1.02rem;
  }
  .course-desc {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    margin-top: 0.6rem;
    flex-grow: 1;
  }
  .course-note {
    color: var(--color-accent-soft);
    font-size: 0.8rem;
    margin-top: 0.6rem;
  }

  .courses-cta {
    text-align: center;
    margin-top: 1rem;
    padding: 2.5rem 1rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .courses-cta p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .courses-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
