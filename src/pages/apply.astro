---
import Layout from '../layouts/Layout.astro';
import { GAS_URL, LINE_URL } from '../consts';
import { getCourses } from '../lib/notion';

const courses = (await getCourses()).filter((c) => c.payable);
const yen = (n: number) => '¥' + n.toLocaleString('ja-JP');
---

<Layout
  title="講座のお申し込み｜Branch"
  description="Branch の講座のお申し込みページです。会員の方は会員価格でお申し込みいただけます。"
>
  <section class="section">
    <div class="container narrow">
      <h1 class="page-title">講座のお申し込み</h1>
      <p class="page-lead">
        受講したい講座を選んでお申し込みください。<br />
        <strong>会員の方は会員価格</strong>でご受講いただけます。
      </p>

      {
        courses.length === 0 ? (
          <p class="empty">
            現在オンラインでお申し込みいただける講座はありません。
            {LINE_URL && (
              <>
                <br />
                <a href={LINE_URL} target="_blank" rel="noopener noreferrer">公式LINE</a> よりお問い合わせください。
              </>
            )}
          </p>
        ) : (
          <form id="apply-form" class="apply-form">
            <div class="field">
              <label for="course">講座<span class="req">必須</span></label>
              <select id="course" name="course" required>
                <option value="" disabled selected>講座を選択</option>
                {courses.map((c) => (
                  <option
                    value={c.pageId}
                    data-member={c.memberPrice}
                    data-non={c.nonMemberPrice}
                  >
                    {c.name}
                  </option>
                ))}
              </select>
            </div>

            <div class="field">
              <span class="label-like">ご区分<span class="req">必須</span></span>
              <div class="radio-row">
                <label class="radio">
                  <input type="radio" name="kind" value="member" checked />
                  <span>会員</span>
                </label>
                <label class="radio">
                  <input type="radio" name="kind" value="guest" />
                  <span>一般（非会員）</span>
                </label>
              </div>
            </div>

            <div class="field" id="member-field">
              <label for="memberNo">会員番号<span class="req">必須</span></label>
              <input type="text" id="memberNo" name="memberNo" placeholder="例：BR-001" autocomplete="off" />
              <small class="hint">会員証・ご案内に記載の番号です。お名前と合わせて確認します。</small>
            </div>

            <div class="field">
              <label for="name">お名前<span class="req">必須</span></label>
              <input type="text" id="name" name="name" placeholder="お名前" autocomplete="name" required />
            </div>

            <div class="field">
              <label for="email">メールアドレス<span class="opt">任意</span></label>
              <input type="email" id="email" name="email" placeholder="example@email.com" autocomplete="email" />
            </div>

            <div class="price-box">
              <span>お支払い金額</span>
              <strong id="price">—</strong>
            </div>

            <button type="submit" id="submit-btn" class="btn btn-primary submit-btn">
              この内容で申し込む
            </button>

            <p id="result" class="result" role="status" aria-live="polite"></p>
          </form>
        )
      }
    </div>
  </section>
</Layout>

<script define:vars={{ GAS_URL, BASE: import.meta.env.BASE_URL }}>
  const form = document.getElementById('apply-form');
  if (form) {
    const courseSel = document.getElementById('course');
    const memberField = document.getElementById('member-field');
    const memberNo = document.getElementById('memberNo');
    const priceEl = document.getElementById('price');
    const submitBtn = document.getElementById('submit-btn');
    const resultEl = document.getElementById('result');
    const kindInputs = form.querySelectorAll('input[name="kind"]');

    const isMember = () => form.querySelector('input[name="kind"]:checked').value === 'member';
    const yen = (n) => '¥' + Number(n).toLocaleString('ja-JP');

    function updatePrice() {
      const opt = courseSel.options[courseSel.selectedIndex];
      memberField.hidden = !isMember();
      memberNo.required = isMember();
      if (!opt || !opt.value) {
        priceEl.textContent = '—';
        return;
      }
      const v = isMember() ? opt.dataset.member : opt.dataset.non;
      priceEl.textContent = Number(v) > 0 ? yen(v) : '要お問い合わせ';
    }
    courseSel.addEventListener('change', updatePrice);
    kindInputs.forEach((r) => r.addEventListener('change', updatePrice));
    updatePrice();

    function show(msg, type) {
      resultEl.textContent = msg;
      resultEl.className = 'result ' + (type || '');
    }

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      show('', '');
      const courseId = courseSel.value;
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const no = isMember() ? memberNo.value.trim() : '';
      if (!courseId || !name) {
        show('講座とお名前を入力してください。', 'error');
        return;
      }
      if (isMember() && !no) {
        show('会員番号を入力してください。', 'error');
        return;
      }

      const basePath = (BASE || '/').replace(/\/$/, '');
      const completeUrl = window.location.origin + basePath + '/apply/complete/';
      const cancelUrl = window.location.origin + basePath + '/apply/';

      submitBtn.disabled = true;
      submitBtn.textContent = '送信中…';
      try {
        const res = await fetch(GAS_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify({
            action: 'course_checkout',
            courseId, name, email, memberNo: no,
            completeUrl, cancelUrl,
          }),
        });
        const data = await res.json();
        if (data.status === 'checkout' && data.url) {
          show('決済ページへ移動します…', '');
          window.location.href = data.url;
          return;
        } else if (data.status === 'applied') {
          show(`✓ ${data.message}（${data.course} / ${yen(data.amount)}）`, 'success');
          form.reset();
          updatePrice();
        } else {
          show(data.message || 'お申し込みできませんでした。', 'error');
        }
      } catch (e) {
        console.error(e);
        show('送信に失敗しました。通信環境をご確認ください。', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'この内容で申し込む';
      }
    });

    // 決済キャンセルで戻ってきた場合
    if (new URLSearchParams(window.location.search).get('canceled')) {
      show('お支払いがキャンセルされました。もう一度お手続きください。', 'error');
    }
  }
</script>

<style>
  .narrow {
    max-width: 560px;
  }
  .page-title {
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    margin-bottom: 1rem;
  }
  .page-lead {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .empty {
    color: var(--color-text-muted);
    text-align: center;
  }
  .apply-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius, 14px);
    padding: 2rem;
    display: grid;
    gap: 1.3rem;
    box-shadow: var(--shadow, 0 10px 30px rgba(0, 0, 0, 0.06));
  }
  .field {
    display: grid;
    gap: 0.45rem;
  }
  .field label,
  .label-like {
    font-weight: 600;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .req,
  .opt {
    font-size: 0.68rem;
    font-weight: 700;
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
  }
  .req {
    color: #fff;
    background: var(--color-primary);
  }
  .opt {
    color: var(--color-text-muted);
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
  }
  .field input,
  .field select {
    width: 100%;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
    font-family: inherit;
  }
  .field input:focus,
  .field select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(111, 168, 69, 0.18);
  }
  .hint {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .radio-row {
    display: flex;
    gap: 1.5rem;
  }
  .radio {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 400;
    cursor: pointer;
  }
  .radio input {
    width: auto;
  }
  .price-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.9rem 1.1rem;
    font-size: 0.95rem;
  }
  .price-box strong {
    font-size: 1.4rem;
    color: var(--color-primary-soft);
  }
  .submit-btn {
    width: 100%;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-family: inherit;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .result {
    margin: 0;
    text-align: center;
    font-size: 0.93rem;
    min-height: 1.2em;
  }
  .result.success {
    color: var(--color-primary-soft);
    font-weight: 700;
  }
  .result.error {
    color: #d9534f;
  }
</style>
