---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { authors, getAuthor } from '../../../data/authors';

export async function getStaticPaths() {
  return authors.map((a) => ({ params: { id: a.id } }));
}

const { id } = Astro.params;
const author = getAuthor(id!);

const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const fmtDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;

const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.author === id)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout
  title={`${author?.name ?? '占い師'}の記事｜Branch`}
  description={`${author?.name ?? ''} が綴るブログ記事の一覧です。`}
>
  <section class="section">
    <div class="container">
      <a class="back" href={link('/blog')}>← ブログ一覧へ</a>

      {
        author && (
          <header class="author-head">
            <img src={asset(author.image)} alt={`${author.name}の写真`} />
            <div>
              <h1 class="author-name">{author.name}</h1>
              {author.kana && <p class="author-kana">{author.kana}</p>}
              <p class="author-role">{author.role}</p>
            </div>
          </header>
        )
      }

      {
        posts.length === 0 ? (
          <p class="empty">まだ記事がありません。</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-card">
                <a class="post-link" href={link(`/blog/${post.id}`)}>
                  <span class="post-date">{fmtDate(post.data.publishDate)}</span>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.excerpt && (
                    <p class="post-excerpt">{post.data.excerpt}</p>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .back {
    display: inline-block;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .author-head {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .author-head img {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }
  .author-name {
    font-size: 1.5rem;
  }
  .author-kana {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .author-role {
    color: var(--color-primary-soft);
    font-size: 0.95rem;
  }
  .empty {
    text-align: center;
    color: var(--color-text-muted);
  }
  .post-list {
    list-style: none;
    display: grid;
    gap: 1.25rem;
    max-width: 760px;
    margin-inline: auto;
  }
  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(91, 145, 53, 0.14);
  }
  .post-link {
    display: block;
    padding: 1.4rem 1.6rem;
    color: inherit;
  }
  .post-date {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .post-title {
    font-size: 1.2rem;
    margin: 0.35rem 0 0.5rem;
  }
  .post-excerpt {
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }
</style>
